+// TestOutputMerger_WaitIdempotent: a second Wait must not panic (the first
+// Wait closes merger.Output; the second should be a no-op). Mirrors the
+// pre-existing double-close landmine in device.go: Multiplex (when given
+// a Console) used to call merger.Wait, and instance.Close also calls it —
+// prior to sync.Once, a second close(Output) would panic.
+func TestOutputMerger_WaitIdempotent(t *testing.T) {
+	// No sources → Wait returns immediately and closes Output.
+	merger := NewOutputMerger(nil)
+	merger.Wait()
+
+	// Second Wait must not panic.
+	done := make(chan struct{})
+	go func() {
+		defer close(done)
+		merger.Wait()
+	}()
+	select {
+	case <-done:
+	case <-time.After(time.Second):
+		t.Fatal("second Wait did not return within 1s")
+	}
+
+	// Output must be closed.
+	select {
+	case _, ok := <-merger.Output:
+		if ok {
+			t.Fatal("Output receive returned ok=true on a Wait'd merger")
+		}
+	default:
+		t.Fatal("receive on closed channel should not block")
+	}
+}
