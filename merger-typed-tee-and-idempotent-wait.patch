+// testTypedSink is a TypedWriter for merger tests. It records both typed
+// and untyped writes so we can verify the merger dispatches correctly.
+type testTypedSink struct {
+	mu      sync.Mutex
+	typed   bytes.Buffer
+	untyped bytes.Buffer
+}
+
+func (t *testTypedSink) Write(p []byte) (int, error) {
+	t.mu.Lock()
+	defer t.mu.Unlock()
+	return t.untyped.Write(p)
+}
+
+func (t *testTypedSink) WriteTyped(typ OutputType, name string, p []byte) (int, error) {
+	t.mu.Lock()
+	defer t.mu.Unlock()
+	return fmt.Fprintf(&t.typed, "[%s/%d] %s", name, typ, p)
+}
+
+func (t *testTypedSink) snapshot() (typed, untyped string) {
+	t.mu.Lock()
+	defer t.mu.Unlock()
+	return t.typed.String(), t.untyped.String()
+}
+
+// TestMerger_DispatchesTypedWriter: when the tee implements TypedWriter,
+// runDecoder must call WriteTyped with the source name + type, NOT
+// Write. Plain io.Writer tees (bytes.Buffer, os.Stdout) must continue to
+// receive untyped Write calls (covered by the pre-existing TestMerger).
+func TestMerger_DispatchesTypedWriter(t *testing.T) {
+	sink := &testTypedSink{}
+	merger := NewOutputMerger(sink)
+
+	rp, wp, err := osutil.LongPipe()
+	if err != nil {
+		t.Fatal(err)
+	}
+	merger.Add("source-a", OutputStdout, rp)
+
+	wp.Write([]byte("hello\nworld\n"))
+
+	// Drain two chunks (the merger emits whole lines).
+	deadline := time.Now().Add(time.Second)
+	for time.Now().Before(deadline) {
+		typed, _ := sink.snapshot()
+		if typed == "[source-a/1] hello\n[source-a/1] world\n" {
+			break
+		}
+		time.Sleep(5 * time.Millisecond)
+	}
+	typed, untyped := sink.snapshot()
+	if typed != "[source-a/1] hello\n[source-a/1] world\n" {
+		t.Fatalf("typed sink got %q, want per-line prefixes", typed)
+	}
+	if untyped != "" {
+		t.Fatalf("typed-capable sink received untyped Write: %q", untyped)
+	}
+
+	wp.Close()
+	// Drain output channel so Wait can close it.
+	go func() {
+		for range merger.Output {
+		}
+	}()
+	merger.Wait()
+}
