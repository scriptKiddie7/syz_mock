+// TestPrefixLines exercises the helper directly. Covers empty, single,
+// multi-line, and trailing-partial-line inputs.
+func TestPrefixLines(t *testing.T) {
+	tests := []struct {
+		name, src, want string
+	}{
+		{"empty", "", ""},
+		{"single-line", "hello\n", "[c] hello\n"},
+		{"two-lines", "a\nb\n", "[c] a\n[c] b\n"},
+		{"trailing-partial", "a\npartial", "[c] a\n[c] partial"},
+		{"just-newline", "\n", "[c] \n"},
+		{"no-newline", "partial", "[c] partial"},
+	}
+	for _, tc := range tests {
+		t.Run(tc.name, func(t *testing.T) {
+			got := prefixLines([]byte(tc.src), "c")
+			if string(got) != tc.want {
+				t.Fatalf("prefixLines(%q, c) = %q, want %q", tc.src, got, tc.want)
+			}
+		})
+	}
+}
