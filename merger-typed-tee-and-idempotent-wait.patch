+// Writer returns this sink as an io.Writer. The returned value also
+// implements vmimpl.TypedWriter, which the merger detects via type
+// assertion and uses for per-source prefixing.
+func (d *DebugSink) Writer() io.Writer { return d }
 
+// Write implements io.Writer. Used by the merger when no TypedWriter is
+// detected (not the case for DebugSink since it implements TypedWriter,
+// but Write is exposed so direct callers — e.g. tests — can still write
+// raw bytes without a source name).
+func (d *DebugSink) Write(p []byte) (int, error) {
+	return d.writeBoth(p)
+}
+
+// WriteTyped implements vmimpl.TypedWriter. Each line in p is prefixed
+// with "[<name>] " before being broadcast to the file and TCP clients.
+// Caller (merger.runDecoder, under merger.teeMu) passes line-aligned
+// chunks ending in '\n', though we tolerate a trailing partial line.
+func (d *DebugSink) WriteTyped(typ OutputType, name string, p []byte) (int, error) {
+	return d.writeBoth(prefixLines(p, name))
+}
+
+// writeBoth writes p to the file (if open) and the TCP broadcaster (if
+// listening). Per-writer errors are handled internally (onceFileWriter
+// log-and-swallow for file; non-blocking channel send for TCP) so this
+// never returns a short write.
+func (d *DebugSink) writeBoth(p []byte) (int, error) {
+	if d.file != nil {
+		_, _ = d.file.Write(p)
+	}
+	if d.tcp != nil {
+		_, _ = d.tcp.Write(p)
+	}
+	return len(p), nil
+}
+
+// prefixLines returns a new buffer with "[name] " prepended to every line
+// in p. Handles multi-line chunks and trailing partial lines. Zero-copy
+// fast path for empty input.
+func prefixLines(p []byte, name string) []byte {
+	if len(p) == 0 {
+		return nil
+	}
+	prefix := make([]byte, 0, len(name)+3)
+	prefix = append(prefix, '[')
+	prefix = append(prefix, name...)
+	prefix = append(prefix, ']', ' ')
+	lineCount := bytes.Count(p, []byte{'\n'})
+	if p[len(p)-1] != '\n' {
+		lineCount++ // trailing partial line (no newline)
+	}
+	out := make([]byte, 0, len(p)+lineCount*len(prefix))
+	start := 0
+	for i := 0; i < len(p); i++ {
+		if p[i] == '\n' {
+			out = append(out, prefix...)
+			out = append(out, p[start:i+1]...)
+			start = i + 1
+		}
+	}
+	if start < len(p) {
+		out = append(out, prefix...)
+		out = append(out, p[start:]...)
+	}
+	return out
+}
+
 // Endpoint returns the listening port (0 if TCP unavailable) and absolute
 // log file path ("" if file unavailable).
 func (d *DebugSink) Endpoint() (port int, path string) {
