+// TestOnceFileWriter_SuppressesRepeatedErrors: once a write fails, the
+// wrapper must swallow subsequent errors silently.
+func TestOnceFileWriter_SuppressesRepeatedErrors(t *testing.T) {
+	f, err := os.CreateTemp(t.TempDir(), "once-*")
+	if err != nil {
+		t.Fatal(err)
+	}
+	w := newOnceFileWriter(f, f.Name())
+	f.Close() // force subsequent Writes to fail
+
+	for i := 0; i < 5; i++ {
+		n, err := w.Write([]byte("data"))
+		if err != nil {
+			t.Fatalf("Write %d returned error: %v (should be swallowed)", i, err)
+		}
+		if n != 4 {
+			t.Fatalf("Write %d returned n=%d, want 4", i, n)
+		}
+	}
+	if !w.failed.Load() {
+		t.Fatal("failed flag was not set")
+	}
+}
