+// TestDebugSink_ManifestUpdates: register/unregister must atomically
+// rewrite endpoints.json.
+func TestDebugSink_ManifestUpdates(t *testing.T) {
+	dir := t.TempDir()
+	base := pickFreePortBase(t)
+
+	s0, err := NewDebugSink(DebugSinkOpts{GlobalWorkdir: dir, VMName: "vm-a", Index: 0, PortBase: base})
+	if err != nil {
+		t.Fatal(err)
+	}
+	s1, err := NewDebugSink(DebugSinkOpts{GlobalWorkdir: dir, VMName: "vm-b", Index: 1, PortBase: base})
+	if err != nil {
+		t.Fatal(err)
+	}
+
+	manifest := filepath.Join(dir, "debug", "endpoints.json")
+	entries := readManifest(t, manifest)
+	if len(entries) != 2 {
+		t.Fatalf("manifest has %d entries, want 2", len(entries))
+	}
+
+	if err := s0.Close(); err != nil {
+		t.Fatal(err)
+	}
+	entries = readManifest(t, manifest)
+	if len(entries) != 1 || entries[0].Index != 1 {
+		t.Fatalf("after closing s0: entries=%+v", entries)
+	}
+
+	if err := s1.Close(); err != nil {
+		t.Fatal(err)
+	}
+	entries = readManifest(t, manifest)
+	if len(entries) != 0 {
+		t.Fatalf("after closing all, entries=%+v", entries)
+	}
+}
