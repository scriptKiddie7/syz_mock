+// Use of this source code is governed by Apache 2 LICENSE that can be found in the LICENSE file.
+
+package vmimpl
+
+import (
+	"bytes"
+	"encoding/json"
+	"io"
+	"net"
+	"os"
+	"path/filepath"
+	"testing"
+	"time"
+)
+
+// TestBroadcaster_DropsSlowClient: a client that never reads must not
+// stall Write. After enough writes, the slow client must be removed.
+func TestBroadcaster_DropsSlowClient(t *testing.T) {
+	ln, err := net.Listen("tcp", "127.0.0.1:0")
+	if err != nil {
+		t.Fatal(err)
+	}
+	b := newTCPBroadcaster(ln)
+	defer b.Close()
+
+	conn, err := net.Dial("tcp", ln.Addr().String())
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer conn.Close()
+
+	if !waitClients(b, 1, time.Second) {
+		t.Fatal("client never registered")
+	}
+
+	payload := bytes.Repeat([]byte("X"), 1024)
+	start := time.Now()
+	for i := 0; i < 10000; i++ {
+		if _, err := b.Write(payload); err != nil {
+			t.Fatalf("Write returned error: %v", err)
+		}
+	}
+	if elapsed := time.Since(start); elapsed > 2*time.Second {
+		t.Fatalf("Write blocked: 10000 writes took %v", elapsed)
+	}
+
+	if !waitClients(b, 0, 5*time.Second) {
+		t.Fatal("slow client was not dropped")
+	}
+}
+
+// TestBroadcaster_CloseDrainsAccept: Close must release the accept loop
+// promptly even if no client is connected.
+func TestBroadcaster_CloseDrainsAccept(t *testing.T) {
+	ln, err := net.Listen("tcp", "127.0.0.1:0")
+	if err != nil {
+		t.Fatal(err)
+	}
+	b := newTCPBroadcaster(ln)
+
+	done := make(chan struct{})
+	go func() {
+		_ = b.Close()
+		close(done)
+	}()
+	select {
+	case <-done:
+	case <-time.After(2 * time.Second):
+		t.Fatal("Close did not return within 2s")
+	}
+}
+
+// TestBroadcaster_WriteCopiesBuffer: Write must copy its argument so that
+// the caller (OutputMerger.runDecoder) is free to mutate `pending`
+// immediately after Write returns.
+func TestBroadcaster_WriteCopiesBuffer(t *testing.T) {
+	ln, err := net.Listen("tcp", "127.0.0.1:0")
+	if err != nil {
+		t.Fatal(err)
+	}
+	b := newTCPBroadcaster(ln)
+	defer b.Close()
+
+	conn, err := net.Dial("tcp", ln.Addr().String())
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer conn.Close()
+
+	if !waitClients(b, 1, time.Second) {
+		t.Fatal("client never registered")
+	}
+
+	buf := []byte("hello")
+	if _, err := b.Write(buf); err != nil {
+		t.Fatal(err)
+	}
+	buf[0] = 'X' // mutate caller buffer immediately
+
+	got := make([]byte, 5)
+	_ = conn.SetReadDeadline(time.Now().Add(2 * time.Second))
+	if _, err := io.ReadFull(conn, got); err != nil {
+		t.Fatal(err)
+	}
+	if string(got) != "hello" {
+		t.Fatalf("client received %q, want %q (Write did not copy)", got, "hello")
+	}
+}
