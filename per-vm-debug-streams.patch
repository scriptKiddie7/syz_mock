+// TestDebugSink_FileAppendsAcrossOpens: opening, writing, closing, then
+// reopening with the same opts must yield a file containing both writes.
+func TestDebugSink_FileAppendsAcrossOpens(t *testing.T) {
+	dir := t.TempDir()
+	opts := DebugSinkOpts{GlobalWorkdir: dir, VMName: "test", Index: 0, PortBase: pickFreePortBase(t)}
+
+	s1, err := NewDebugSink(opts)
+	if err != nil {
+		t.Fatal(err)
+	}
+	if _, err := s1.Writer().Write([]byte("first\n")); err != nil {
+		t.Fatal(err)
+	}
+	if err := s1.Close(); err != nil {
+		t.Fatal(err)
+	}
+
+	s2, err := NewDebugSink(opts)
+	if err != nil {
+		t.Fatal(err)
+	}
+	if _, err := s2.Writer().Write([]byte("second\n")); err != nil {
+		t.Fatal(err)
+	}
+	_, path := s2.Endpoint()
+	if err := s2.Close(); err != nil {
+		t.Fatal(err)
+	}
+
+	data, err := os.ReadFile(path)
+	if err != nil {
+		t.Fatal(err)
+	}
+	if got := string(data); got != "first\nsecond\n" {
+		t.Fatalf("file = %q, want %q", got, "first\nsecond\n")
+	}
+}
