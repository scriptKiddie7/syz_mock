--- /dev/null
+++ b/vm/vmimpl/debugsink.go
@@ -0,0 +1,397 @@
+// Copyright 2026 syzkaller project authors. All rights reserved.
+// Use of this source code is governed by Apache 2 LICENSE that can be found in the LICENSE file.
+
+// DebugSink: per-VM debug stream destination.
+//
+// When syz-manager is run with -debug-streams, each VM/device instance gets
+// its own DebugSink which is passed to NewOutputMerger as the tee target.
+// The sink fans every line out to two destinations:
+//
+//   1. An append-only log file at <workdir>/debug/vm-<index>.log. The file
+//      uses O_APPEND so console history survives Pool.Create cycles
+//      (e.g. across device reboots).
+//
+//   2. A localhost TCP listener on 127.0.0.1:<base+index> (default base
+//      6000, falling back to an ephemeral port if the preferred one is
+//      busy). Any number of clients (PuTTY, TeraTerm, ncat) can attach
+//      and receive the live stream.
+//
+// Sink lifetime is owned by the backend Instance, NOT by the OutputMerger
+// (the merger only ever calls Write on its tee, never Close). This lets
+// the file and listener persist across multiple Run() calls within the
+// same Instance.
+//
+// Critical invariant: TCPBroadcaster.Write performs no I/O. It copies the
+// caller's buffer (because OutputMerger.runDecoder reuses its `pending`
+// slice), takes a mutex, performs O(N_clients) non-blocking channel sends,
+// and returns. Slow clients are silently dropped when their per-client
+// queue fills. This guarantees runDecoder cannot stall on tee, which
+// would otherwise risk a spurious noOutputCrash.
+
+package vmimpl
+
+import (
+	"encoding/json"
+	"errors"
+	"fmt"
+	"io"
+	"net"
+	"os"
+	"path/filepath"
+	"sort"
+	"sync"
+	"sync/atomic"
+	"time"
+
+	"github.com/google/syzkaller/pkg/log"
+	"github.com/google/syzkaller/pkg/osutil"
+)
+
+// DefaultDebugPortBase is the default TCP base port for per-VM debug streams.
+// Each VM index adds to this base: VM 0 listens on 6000, VM 1 on 6001, etc.
+const DefaultDebugPortBase = 6000
+
+// tcpClientQueueSize bounds memory per connected client. Lines exceeding
+// this queue cause the slow client to be dropped.
+const tcpClientQueueSize = 128
+
+// tcpWriteDeadline bounds how long a single conn.Write may stall before the
+// client is considered dead.
+const tcpWriteDeadline = 2 * time.Second
+
+// DebugSinkOpts configures a per-VM debug sink.
+type DebugSinkOpts struct {
+	// GlobalWorkdir is typically cfg.Workdir; the "debug/" subdir lives here.
+	GlobalWorkdir string
+	// VMName is env.Name; recorded in the manifest only.
+	VMName string
+	// Index is the VM index; determines TCP port and log file name.
+	Index int
+	// PortBase: 0 means use DefaultDebugPortBase.
+	PortBase int
+}
+
+// DebugSink owns one append-only log file and one TCP listener. Its single
+// io.Writer (via Writer()) is intended to be passed to NewOutputMerger as
+// the tee target.
+type DebugSink struct {
+	file io.WriteCloser  // wrapped with onceFileWriter; may be nil if open failed
+	tcp  *TCPBroadcaster // may be nil if listener init failed
+	w    io.Writer       // composed writer passed to merger
+
+	name  string
+	index int
+	port  int    // chosen port (0 if TCP unavailable)
+	path  string // absolute log file path ("" if file unavailable)
+
+	closeOnce sync.Once
+	closeErr  error
+}
+
+// NewDebugSink opens the per-VM log file and TCP listener. Returns an error
+// only if BOTH fail; if just one fails, the sink degrades gracefully.
+func NewDebugSink(opts DebugSinkOpts) (*DebugSink, error) {
+	portBase := opts.PortBase
+	if portBase == 0 {
+		portBase = DefaultDebugPortBase
+	}
+	debugDir := filepath.Join(opts.GlobalWorkdir, "debug")
+	if err := osutil.MkdirAll(debugDir); err != nil {
+		return nil, fmt.Errorf("debug dir: %w", err)
+	}
+
+	d := &DebugSink{name: opts.VMName, index: opts.Index}
+	d.path = filepath.Join(debugDir, fmt.Sprintf("vm-%d.log", opts.Index))
+
+	// File: O_APPEND so history survives Pool.Create cycles.
+	f, ferr := os.OpenFile(d.path, os.O_CREATE|os.O_WRONLY|os.O_APPEND, 0644)
+	if ferr == nil {
+		d.file = newOnceFileWriter(f, d.path)
+	} else {
+		log.Logf(0, "debug sink vm %d: file %s open failed: %v", opts.Index, d.path, ferr)
+		d.path = ""
+	}
+
+	// TCP: try preferred port first; on failure, fall back to ephemeral.
+	preferred := fmt.Sprintf("127.0.0.1:%d", portBase+opts.Index)
+	ln, lerr := net.Listen("tcp", preferred)
+	if lerr != nil {
+		log.Logf(0, "debug sink vm %d: preferred port %s busy (%v); falling back to ephemeral",
+			opts.Index, preferred, lerr)
+		ln, lerr = net.Listen("tcp", "127.0.0.1:0")
+	}
+	if lerr == nil {
+		d.tcp = newTCPBroadcaster(ln)
+		d.port = ln.Addr().(*net.TCPAddr).Port
+	} else {
+		log.Logf(0, "debug sink vm %d: TCP listener failed: %v", opts.Index, lerr)
+	}
+
+	if d.file == nil && d.tcp == nil {
+		return nil, errors.New("both file and TCP listener failed")
+	}
+
+	switch {
+	case d.file != nil && d.tcp != nil:
+		d.w = io.MultiWriter(d.file, d.tcp)
+	case d.file != nil:
+		d.w = d.file
+	default:
+		d.w = d.tcp
+	}
+
+	debugRegistry.register(d, opts.GlobalWorkdir)
+	return d, nil
+}
+
+// Writer returns the io.Writer to pass as the tee target to NewOutputMerger.
+func (d *DebugSink) Writer() io.Writer { return d.w }
+
+// Endpoint returns the listening port (0 if TCP unavailable) and absolute
+// log file path ("" if file unavailable).
+func (d *DebugSink) Endpoint() (port int, path string) {
+	return d.port, d.path
+}
+
+// Close is idempotent. Releases the TCP listener, drains client writers,
+// and closes the file.
+func (d *DebugSink) Close() error {
+	d.closeOnce.Do(func() {
+		debugRegistry.unregister(d)
+		if d.tcp != nil {
+			d.closeErr = d.tcp.Close()
+		}
+		if d.file != nil {
+			if err := d.file.Close(); err != nil && d.closeErr == nil {
+				d.closeErr = err
+			}
+		}
+	})
+	return d.closeErr
+}
+
+// onceFileWriter logs the first write error via golog and swallows
+// subsequent ones, so a full disk does not propagate as a tee error
+// nor flood the manager log.
+type onceFileWriter struct {
+	f      *os.File
+	path   string
+	failed atomic.Bool
+}
+
+func newOnceFileWriter(f *os.File, path string) *onceFileWriter {
+	return &onceFileWriter{f: f, path: path}
+}
+
+func (w *onceFileWriter) Write(p []byte) (int, error) {
+	if w.failed.Load() {
+		return len(p), nil
+	}
+	n, err := w.f.Write(p)
+	if err != nil {
+		if w.failed.CompareAndSwap(false, true) {
+			log.Logf(0, "debug sink: write to %s failed (further errors suppressed): %v",
+				w.path, err)
+		}
+		return len(p), nil
+	}
+	return n, nil
+}
+
+func (w *onceFileWriter) Close() error { return w.f.Close() }
+
+// TCPBroadcaster fans every Write out to all connected clients via per-client
+// queues. Write never performs I/O, so it cannot stall the OutputMerger's
+// runDecoder loop. Slow clients are dropped silently when their queue fills.
+type TCPBroadcaster struct {
+	ln      net.Listener
+	mu      sync.Mutex
+	clients []*tcpClient
+	wg      sync.WaitGroup
+	closed  atomic.Bool
+}
+
+type tcpClient struct {
+	conn  net.Conn
+	queue chan []byte
+}
+
+func newTCPBroadcaster(ln net.Listener) *TCPBroadcaster {
+	b := &TCPBroadcaster{ln: ln}
+	b.wg.Add(1)
+	go b.acceptLoop()
+	return b
+}
+
+func (b *TCPBroadcaster) acceptLoop() {
+	defer b.wg.Done()
+	for {
+		conn, err := b.ln.Accept()
+		if err != nil {
+			return // listener closed
+		}
+		c := &tcpClient{conn: conn, queue: make(chan []byte, tcpClientQueueSize)}
+		b.mu.Lock()
+		if b.closed.Load() {
+			b.mu.Unlock()
+			conn.Close()
+			return
+		}
+		b.clients = append(b.clients, c)
+		b.mu.Unlock()
+		b.wg.Add(1)
+		go b.writeLoop(c)
+	}
+}
+
+func (b *TCPBroadcaster) writeLoop(c *tcpClient) {
+	defer b.wg.Done()
+	defer c.conn.Close()
+	for buf := range c.queue {
+		_ = c.conn.SetWriteDeadline(time.Now().Add(tcpWriteDeadline))
+		if _, err := c.conn.Write(buf); err != nil {
+			// Remove ourselves from the broadcaster under mu, then exit.
+			// We do NOT close the queue here: Write's send is non-blocking
+			// (select with default) so it can never deadlock on this queue.
+			// Any in-flight Write that already enqueued before our
+			// removeClient acquired mu has its buffer GC'd along with the
+			// unreferenced client struct after writeLoop returns.
+			b.removeClient(c)
+			return
+		}
+	}
+}
+
+// removeClient atomically removes a client from the broadcaster's list.
+// Called from writeLoop on Write error. After this returns, no further
+// Write call will try to send to this client's queue (Write iterates
+// b.clients under the same mu).
+func (b *TCPBroadcaster) removeClient(target *tcpClient) {
+	b.mu.Lock()
+	defer b.mu.Unlock()
+	for i, c := range b.clients {
+		if c == target {
+			b.clients = append(b.clients[:i], b.clients[i+1:]...)
+			return
+		}
+	}
+}
+
+// Write is non-blocking. p is copied because the caller (merger.runDecoder)
+// reuses its `pending` buffer.
+func (b *TCPBroadcaster) Write(p []byte) (int, error) {
+	if b.closed.Load() {
+		return len(p), nil
+	}
+	cp := append([]byte(nil), p...)
+	b.mu.Lock()
+	defer b.mu.Unlock()
+	for i := len(b.clients) - 1; i >= 0; i-- {
+		select {
+		case b.clients[i].queue <- cp:
+		default:
+			// Slow client: drop it. Close its queue so its writeLoop
+			// observes range exit and tears the connection down.
+			close(b.clients[i].queue)
+			b.clients = append(b.clients[:i], b.clients[i+1:]...)
+		}
+	}
+	return len(p), nil
+}
+
+// Close releases the listener, closes all live client queues, and waits
+// for all goroutines (acceptLoop + writeLoops) to exit.
+func (b *TCPBroadcaster) Close() error {
+	if !b.closed.CompareAndSwap(false, true) {
+		return nil
+	}
+	err := b.ln.Close()
+	b.mu.Lock()
+	for _, c := range b.clients {
+		// Channel may already be closed if writeLoop drained on error;
+		// guard with recover via defensive send-then-close pattern.
+		safeClose(c.queue)
+	}
+	b.clients = nil
+	b.mu.Unlock()
+	b.wg.Wait()
+	return err
+}
+
+// safeClose closes a channel that may already be closed (no-op in that
+// case). Safer than relying on Close path being the only closer.
+func safeClose(ch chan []byte) {
+	defer func() { _ = recover() }()
+	close(ch)
+}
+
+// debugRegistry is the package-level registry of live DebugSinks. It writes
+// <workdir>/debug/endpoints.json atomically whenever sinks are registered
+// or unregistered, so external tooling (PuTTY profile launcher scripts,
+// dashboards, etc.) can discover live ports and log paths.
+type debugRegistryT struct {
+	mu      sync.Mutex
+	workdir string
+	sinks   map[string]*DebugSink // key: "vm-<index>"
+}
+
+var debugRegistry = &debugRegistryT{sinks: map[string]*DebugSink{}}
+
+func (r *debugRegistryT) register(d *DebugSink, workdir string) {
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	if r.workdir == "" {
+		r.workdir = workdir
+	}
+	r.sinks[fmt.Sprintf("vm-%d", d.index)] = d
+	r.writeManifestLocked()
+}
+
+func (r *debugRegistryT) unregister(d *DebugSink) {
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	delete(r.sinks, fmt.Sprintf("vm-%d", d.index))
+	r.writeManifestLocked()
+}
+
+type manifestEntry struct {
+	Name  string `json:"name"`
+	Index int    `json:"index"`
+	Port  int    `json:"port"`
+	Log   string `json:"log"`
+}
+
+func (r *debugRegistryT) writeManifestLocked() {
+	if r.workdir == "" {
+		return
+	}
+	dir := filepath.Join(r.workdir, "debug")
+	if err := osutil.MkdirAll(dir); err != nil {
+		log.Logf(0, "debug sink: manifest dir: %v", err)
+		return
+	}
+	final := filepath.Join(dir, "endpoints.json")
+	tmp := final + ".tmp"
+
+	entries := make([]manifestEntry, 0, len(r.sinks))
+	for _, d := range r.sinks {
+		entries = append(entries, manifestEntry{
+			Name: d.name, Index: d.index, Port: d.port, Log: d.path,
+		})
+	}
+	sort.Slice(entries, func(i, j int) bool { return entries[i].Index < entries[j].Index })
+
+	data, err := json.MarshalIndent(entries, "", "  ")
+	if err != nil {
+		log.Logf(0, "debug sink: manifest marshal: %v", err)
+		return
+	}
+	if err := os.WriteFile(tmp, data, 0644); err != nil {
+		log.Logf(0, "debug sink: manifest write: %v", err)
+		return
+	}
+	if err := os.Rename(tmp, final); err != nil {
+		log.Logf(0, "debug sink: manifest rename: %v", err)
+		_ = os.Remove(tmp)
+	}
+}
