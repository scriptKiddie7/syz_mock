+// TestDebugSink_PortFallbackOnCollision: if the preferred port is busy,
+// NewDebugSink must fall back to an ephemeral port without failing.
+func TestDebugSink_PortFallbackOnCollision(t *testing.T) {
+	dir := t.TempDir()
+	base := pickFreePortBase(t)
+
+	// Hold the preferred port so the sink must fall back.
+	hold, err := net.Listen("tcp", net.JoinHostPort("127.0.0.1", itoa(base)))
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer hold.Close()
+
+	s, err := NewDebugSink(DebugSinkOpts{GlobalWorkdir: dir, VMName: "test", Index: 0, PortBase: base})
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer s.Close()
+
+	port, _ := s.Endpoint()
+	if port == 0 {
+		t.Fatal("sink got port 0, expected ephemeral fallback")
+	}
+	if port == base {
+		t.Fatalf("sink got preferred port %d, expected fallback", port)
+	}
+}
